# ==========================================
# Application
# ==========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# Database (uncomment when needed)
# ==========================================
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ==========================================
# Authentication (uncomment when needed)
# ==========================================
